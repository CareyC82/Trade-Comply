# Copy to .env.local (git-ignored) and fill in secrets.
# Required to expose /api/test-crawl, /api/review/*, /api/debug (local admin or FC).
ADMIN_ROUTES_ENABLED=1
ADMIN_REVIEW_PASSWORD=your-review-password
# Optional dedicated secret for /api/test-crawl (FC or ?key=); admin Bearer also accepted.
TEST_CRAWL_SECRET=your-test-crawl-secret
DEEPSEEK_API_KEY=sk-your-deepseek-key
