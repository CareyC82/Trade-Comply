{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TradeComplyRiskSignal",
  "type": "object",
  "required": [
    "hs_code",
    "direction",
    "country",
    "risk_level",
    "source",
    "content_en",
    "content_zh"
  ],
  "properties": {
    "signal_id": { "type": "string" },
    "hs_code": { "type": "string", "minLength": 2 },
    "direction": { "enum": ["export", "import"] },
    "country": {
      "enum": ["US", "EU", "ASEAN", "RU", "TW", "JP", "KR", "GLOBAL", "OTHER"]
    },
    "risk_level": { "enum": ["High", "Medium", "Low"] },
    "source": { "type": "string", "minLength": 2 },
    "content_en": { "type": "string", "minLength": 10 },
    "content_zh": { "type": "string", "minLength": 2 },
    "source_url": { "type": ["string", "null"] },
    "related_keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pipeline_source": { "type": "string" },
    "fetched_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": true
}
